    "constrainedSurface.fs": {
      "name": "constrainedSurface",
      "importPath": "onshape/std/constrainedSurface.fs",
      "description": "",
      "symbols": [
        {
          "name": "ConstrainedSurfaceType",
          "kind": "enum",
          "id": "ConstrainedSurfaceType",
          "returnType": null,
          "description": "Constrained surface input type",
          "values": [
            {
              "name": "POINTS",
              "description": null
            },
            {
              "name": "MESH",
              "description": null
            }
          ]
        },
        {
          "name": "OptimizationMethod",
          "kind": "enum",
          "id": "OptimizationMethod",
          "returnType": null,
          "description": "Constrained surface optimization type",
          "values": [
            {
              "name": "PERF",
              "description": "Faster performance that may produce lower-quality surfaces."
            },
            {
              "name": "SMOOTH",
              "description": "Typically produces higher-quality surfaces with lower curvatures, but with slower performance and more control points."
            }
          ]
        },
        {
          "name": "constrainedSurface",
          "kind": "function",
          "id": "constrainedSurface-Context-Id-map",
          "signature": "(context is Context, id is Id, definition is map)",
          "signatureParams": [
            {
              "name": "context",
              "type": "Context"
            },
            {
              "name": "id",
              "type": "Id"
            },
            {
              "name": "definition",
              "type": "map"
            }
          ],
          "returnType": null,
          "description": "Constrained surface feature. Takes an arbitrary number of vertices and optional normal directions or meshes and creates a surface passing through the vertices/mesh points within a provided tolerance. \n\n```\nconstrainedSurface(context, id + \"FG2MuQGCNLssvyp_123\", {\n     \"csType\" : ConstrainedSurfaceType.MESH,\n     \"vertices\" : [],\n     \"meshes\" : qUnion([iLEjUaBPUqVOpC_query]),\n     \"tolerance\" : { 'value' : try(1 * inch), 'expression' : \"1 in\" }.value,\n     \"optimize\" : OptimizationMethod.PERF\n});\n```",
          "parameters": [
            {
              "name": "definition",
              "type": "map",
              "typeRef": "builtin:map",
              "required": true,
              "requiredIf": null,
              "description": null,
              "subfields": [
                {
                  "name": "csType",
                  "type": "ConstrainedSurfaceType",
                  "typeRef": "#ConstrainedSurfaceType",
                  "required": true,
                  "requiredIf": null,
                  "description": "Determines if the input is a mesh or a collection of points."
                },
                {
                  "name": "vertices",
                  "type": "array",
                  "typeRef": "builtin:array",
                  "required": false,
                  "requiredIf": "csType is ConstrainedSurfaceType.POINTS",
                  "description": "Required if `csType` is `ConstrainedSurfaceType.POINTS`An array of elements, each with a `vertex` on the surface to include. Optionally, specify a directional object to set the normal in the `normal` field, and set `flipNormal` to `true` to flip the normal. \n Example: \n\n```\n[\n    {\"vertex\": qVertex1},\n    {\"vertex\": qVertex2},\n    {\"vertex\": qVertex3, \"normal\": qNormal1},\n    {\"vertex\": qVertex4, \"normal\": qNormal2, \"flipNormal\": true}\n]\n```"
                },
                {
                  "name": "meshes",
                  "type": "Query",
                  "typeRef": "#Query",
                  "required": false,
                  "requiredIf": "csType is ConstrainedSurfaceType.MESH",
                  "description": "Required if `csType` is `ConstrainedSurfaceType.MESH`A query of mesh faces or bodies. Each mesh vertex of the query elements is on the constrained surface. \n Example: \n`\"meshes\" : qUnion([iLEjUaBPUqVOpC_query])`"
                },
                {
                  "name": "tolerance",
                  "type": "ValueWithUnits",
                  "typeRef": "#ValueWithUnits",
                  "required": true,
                  "requiredIf": null,
                  "description": "Length to define how far from each vertex the constrained surface can be."
                },
                {
                  "name": "optimize",
                  "type": "OptimizationMethod",
                  "typeRef": "#OptimizationMethod",
                  "required": true,
                  "requiredIf": null,
                  "description": "Whether to optimize for performance (`OptimizationMethod.PERF`) or smoothness (`OptimizationMethod.SMOOTH`)."
                }
              ]
            }
          ],
          "references": [
            "ConstrainedSurfaceType",
            "Query",
            "ValueWithUnits",
            "OptimizationMethod"
          ]
        }
      ]
    },
