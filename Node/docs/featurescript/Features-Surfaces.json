                  "typeRef": "#Vector",
                  "required": true,
                  "requiredIf": null,
                  "description": "The position"
                },
                {
                  "name": "frame",
                  "type": "EdgeCurvatureResult",
                  "typeRef": "#EdgeCurvatureResult",
                  "required": false,
                  "requiredIf": null,
                  "description": "OptionalThe coordSystem and curvature at the given position"
                }
              ]
            }
          ],
          "references": [
            "Vector",
            "EdgeCurvatureResult"
          ]
        },
        {
          "name": "TwoSidesData",
          "kind": "type",
          "id": "TwoSidesData",
          "returnType": null,
          "description": "Aggregation of both sides SideData",
          "parameters": [
            {
              "name": "TwoSidesData",
              "type": "map",
              "typeRef": "builtin:map",
              "required": true,
              "requiredIf": null,
              "description": null,
              "subfields": [
                {
                  "name": "side1",
                  "type": "SideData",
                  "typeRef": "#SideData",
                  "required": true,
                  "requiredIf": null,
                  "description": "SideData map for start side"
                },
                {
                  "name": "side2",
                  "type": "SideData",
                  "typeRef": "#SideData",
                  "required": true,
                  "requiredIf": null,
                  "description": "SideData map for end side"
                }
              ]
            }
          ],
          "references": [
            "SideData"
          ]
        },
        {
          "name": "BridgingSideData",
          "kind": "type",
          "id": "BridgingSideData",
          "returnType": null,
          "description": "Data type for unified control points computation",
          "parameters": [
            {
              "name": "BridgingSideData",
              "type": "map",
              "typeRef": "builtin:map",
              "required": true,
              "requiredIf": null,
              "description": null,
              "subfields": [
                {
                  "name": "degree",
                  "type": "number",
                  "typeRef": "builtin:number",
                  "required": true,
                  "requiredIf": null,
                  "description": "0 for positional continuity (G0), 1 for tangent continuity (G1), 2 for curvature continuity (G2)"
                },
                {
                  "name": "position",
                  "type": "Vector",
                  "typeRef": "#Vector",
                  "required": true,
                  "requiredIf": null,
                  "description": "The position"
                },
                {
                  "name": "tangent",
                  "type": "Vector",
                  "typeRef": "#Vector",
                  "required": false,
                  "requiredIf": "degree &gt;= 1",
                  "description": "Required if `degree` &gt;= 1 The tangent direction vector"
                },
                {
                  "name": "speedScale",
                  "type": "number",
                  "typeRef": "builtin:number",
                  "required": false,
                  "requiredIf": null,
                  "description": "OptionalHow much to scale the default speed"
                },
                {
                  "name": "curvatureDirection",
                  "type": "Vector",
                  "typeRef": "#Vector",
                  "required": false,
                  "requiredIf": "degree == 2",
                  "description": "Required if `degree` == 2 The curvature direction vector"
                },
                {
                  "name": "curvature",
                  "type": "ValueWithUnits",
                  "typeRef": "#ValueWithUnits",
                  "required": false,
                  "requiredIf": "degree == 2",
                  "description": "Required if `degree` == 2 The curvature magnitude (inverse length units)"
                },
                {
                  "name": "curvatureOffsetScale",
                  "type": "number",
                  "typeRef": "builtin:number",
                  "required": false,
                  "requiredIf": null,
                  "description": "OptionalHow much to scale the default third control point offset"
                }
              ]
            }
          ],
          "references": [
            "Vector",
            "ValueWithUnits"
          ]
        },
        {
          "name": "computeBridgingControlPoints",
          "kind": "function",
          "id": "computeBridgingControlPoints-Context-BridgingSideData-BridgingSideData",
          "signature": "(context is Context, side1 is BridgingSideData, side2 is BridgingSideData)",
          "signatureParams": [
            {
              "name": "context",
              "type": "Context"
            },
            {
              "name": "side1",
              "type": "BridgingSideData"
            },
            {
              "name": "side2",
              "type": "BridgingSideData"
            }
          ],
          "returnType": "array",
          "returnTypeRef": "builtin:array",
          "description": "Returns an array of control points for a bridigng bezier curve given two side constraints"
        }
      ]
    },
