    "bridgingCurve.fs": {
      "name": "bridgingCurve",
      "importPath": "onshape/std/bridgingCurve.fs",
      "description": "",
      "symbols": [
        {
          "name": "BridgingCurveMatchType",
          "kind": "enum",
          "id": "BridgingCurveMatchType",
          "returnType": null,
          "description": "Specifies how the bridging curve will match the vertex or edge at each side",
          "values": [
            {
              "name": "POSITION",
              "description": "The bridging curve will end at the provided vertex. Direction of the curve is unspecified"
            },
            {
              "name": "TANGENCY",
              "description": "The bridging curve will end at the vertex and the curve will be tangent to the edge"
            },
            {
              "name": "CURVATURE",
              "description": "The bridging curve will end at the vertex and the curve will have same curvature as the edge at the vertex"
            },
            {
              "name": "G3",
              "description": null
            }
          ]
        },
        {
          "name": "BIAS_BOUNDS",
          "kind": "const",
          "id": "BIAS_BOUNDS",
          "returnType": null,
          "description": "A `RealBoundSpec` for bias of a tangency/tangency bridge, defaulting to `0.5`."
        },
        {
          "name": "bridgingCurve",
          "kind": "function",
          "id": "bridgingCurve-Context-Id-map",
          "signature": "(context is Context, id is Id, definition is map)",
          "signatureParams": [
            {
              "name": "context",
              "type": "Context"
            },
            {
              "name": "id",
              "type": "Id"
            },
            {
              "name": "definition",
              "type": "map"
            }
          ],
          "returnType": null,
          "description": "Creates a curve between two points, optionally with matching of tangency or curvature to other curves at that point"
        },
        {
          "name": "SideQueries",
          "kind": "type",
          "id": "SideQueries",
          "returnType": null,
          "description": "Data type for side queries",
          "parameters": [
            {
              "name": "SideQueries",
              "type": "map",
              "typeRef": "builtin:map",
              "required": true,
              "requiredIf": null,
              "description": null,
