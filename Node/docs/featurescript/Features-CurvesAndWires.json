    "projectCurves.fs": {
      "name": "projectCurves",
      "importPath": "onshape/std/projectCurves.fs",
      "description": "",
      "symbols": [
        {
          "name": "CurveProjectionType",
          "kind": "enum",
          "id": "CurveProjectionType",
          "returnType": null,
          "description": "Specifies the method used for generating intersection curves.",
          "values": [
            {
              "name": "TWO_SKETCHES",
              "description": "Performs `opExtrude` to convert sketches into surface, then uses `opBoolean` to intersect those surfaces."
            },
            {
              "name": "CURVE_TO_FACE",
              "description": "Performs `opDropCurve` to project curves onto faces."
            }
          ]
        },
        {
          "name": "projectCurves",
          "kind": "function",
          "id": "projectCurves-Context-Id-map",
          "signature": "(context is Context, id is Id, definition is map)",
          "signatureParams": [
            {
              "name": "context",
              "type": "Context"
            },
            {
              "name": "id",
              "type": "Id"
            },
            {
              "name": "definition",
              "type": "map"
            }
          ],
          "returnType": null,
          "description": "Feature creating projected curves.",
          "parameters": [
            {
              "name": "definition",
              "type": "map",
              "typeRef": "builtin:map",
              "required": true,
              "requiredIf": null,
              "description": null,
              "subfields": [
                {
                  "name": "curveProjectionType",
                  "type": "CurveProjectionType",
                  "typeRef": "#CurveProjectionType",
                  "required": false,
                  "requiredIf": null,
                  "description": "OptionalThe method used for generating intersection curves. Default is `TWO_SKETCHES`."
                },
                {
                  "name": "sketchEdges1",
                  "type": "Query",
                  "typeRef": "#Query",
                  "required": false,
                  "requiredIf": "curveProjectionType is TWO_SKETCHES",
                  "description": "Required if `curveProjectionType` is `TWO_SKETCHES` Edges from a single sketch that will be extruded to perform an intersection."
                },
                {
                  "name": "sketchEdges2",
                  "type": "Query",
                  "typeRef": "#Query",
                  "required": false,
                  "requiredIf": "curveProjectionType is TWO_SKETCHES",
                  "description": "Required if `curveProjectionType` is `TWO_SKETCHES` Edges from a single sketch that will be extruded to perform an intersection."
                },
                {
                  "name": "dropTools",
                  "type": "Query",
                  "typeRef": "#Query",
                  "required": false,
                  "requiredIf": "curveProjectionType is CURVE_TO_FACE",
                  "description": "Required if `curveProjectionType` is `CURVE_TO_FACE` Edges that will be projected onto `targets`."
                },
                {
                  "name": "projectionType",
                  "type": "ProjectionType",
                  "typeRef": "#ProjectionType",
                  "required": false,
                  "requiredIf": "curveProjectionType is CURVE_TO_FACE",
                  "description": "Required if `curveProjectionType` is `CURVE_TO_FACE` Specifies whether to project along a direction or the face normal of `targets`."
                },
                {
                  "name": "directionQuery",
                  "type": "Query",
                  "typeRef": "#Query",
                  "required": false,
                  "requiredIf": "projectionType is DIRECTION",
                  "description": "Required if `projectionType` is `DIRECTION` Specifies the direction of projection."
                },
                {
                  "name": "oppositeDirection",
                  "type": "boolean",
                  "typeRef": "builtin:boolean",
                  "required": false,
                  "requiredIf": "projectionType is DIRECTION",
                  "description": "Required if `projectionType` is `DIRECTION` If true, negates the direction supplied by `directionQuery`."
                },
                {
                  "name": "targets",
                  "type": "Query",
                  "typeRef": "#Query",
                  "required": false,
                  "requiredIf": "curveProjectionType is CURVE_TO_FACE",
                  "description": "Required if `curveProjectionType` is `CURVE_TO_FACE` Faces, sheet bodies, or solid bodies to project onto."
                }
              ]
            }
          ],
          "references": [
            "CurveProjectionType",
            "Query",
            "ProjectionType"
          ]
        }
      ]
    },
