    "helix.fs": {
      "name": "helix",
      "importPath": "onshape/std/helix.fs",
      "description": "",
      "symbols": [
        {
          "name": "AxisType",
          "kind": "enum",
          "id": "AxisType",
          "returnType": null,
          "description": "Describes the type of body on which to create a helix.",
          "values": [
            {
              "name": "SURFACE",
              "description": "Impose a helix onto a cylinder or cone."
            },
            {
              "name": "AXIS",
              "description": "Revolve a helix around an axial edge or mate connector."
            },
            {
              "name": "CIRCLE",
              "description": "Revolve a helix along a circular path."
            }
          ]
        },
        {
          "name": "PathType",
          "kind": "enum",
          "id": "PathType",
          "returnType": null,
          "description": "Describes the parameter(s) to vary when computing the path of a helix.",
          "values": [
            {
              "name": "TURNS",
              "description": "Allow only the number of turns (revolutions) to be varied."
            },
            {
              "name": "PITCH",
              "description": "Allow only the space between each turn (helical pitch) to be varied."
            },
            {
              "name": "TURNS_PITCH",
              "description": "Allow both turns and pitch to be varied. Always results in a cylindrical helix."
            }
          ]
        },
        {
          "name": "StartType",
          "kind": "enum",
          "id": "StartType",
          "returnType": null,
          "description": "Describes the starting condition of a helix.",
          "values": [
            {
              "name": "START_ANGLE",
              "description": "Start the helix at an angle around the origin of the base."
            },
            {
              "name": "START_POINT",
              "description": "Start the helix at a point of choice along the plane of the base."
            }
          ]
        },
        {
          "name": "EndType",
          "kind": "enum",
          "id": "EndType",
          "returnType": null,
          "description": "Describes the ending condition of a helix.",
          "values": [
            {
              "name": "HEIGHT",
              "description": "End the helix at a specified height."
            },
            {
              "name": "END_POINT",
              "description": "End the helix at a specified point along a perpendicular plane to the base."
            }
          ]
        },
        {
          "name": "Direction",
          "kind": "enum",
          "id": "Direction",
          "returnType": null,
          "description": "Describes the direction a helix turns while traveling along its axis.",
          "values": [
            {
              "name": "CW",
              "description": "Clockwise."
            },
            {
              "name": "CCW",
              "description": "Counterclockwise."
            }
          ]
        },
        {
          "name": "helix",
          "kind": "function",
