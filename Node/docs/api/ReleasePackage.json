        "deprecated": false,
        "security": [
          {
            "OAuth2": [
              "OAuth2Read"
            ],
            "BasicAuth": [
              "OAuth2Read"
            ]
          }
        ],
        "x-BTVisibility": "PRODUCTION"
      },
      "post": {
        "tags": [
          "ReleasePackage"
        ],
        "summary": "Update the release/obsoletion package/item properties.",
        "description": "Use the `wfaction` query param to also perform a workflow transition.",
        "operationId": "updateReleasePackage",
        "parameters": [
          {
            "name": "rpid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "UPDATE"
            }
          },
          {
            "name": "wfaction",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
