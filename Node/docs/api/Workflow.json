        },
        "deprecated": false,
        "security": [
          {
            "OAuth2": [
              "OAuth2Read"
            ],
            "BasicAuth": [
              "OAuth2Read"
            ]
          }
        ],
        "x-BTVisibility": "PRODUCTION"
      }
    }
  },
