            "content": {
              "application/json;charset=UTF-8; qs=0.09": {
                "schema": {
                  "$ref": "#/components/schemas/BTAliasInfo"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OAuth2": [
              "OAuth2Write"
            ],
            "BasicAuth": [
              "OAuth2Write"
            ]
          }
        ],
        "x-BTVisibility": "PRODUCTION"
      },
      "delete": {
